{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/jjpg95/Projects/accounting-server && npx tsc --noEmit 2>&1 | head -40"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx jest *)",
      "Bash(npm test *)",
      "Bash(npx prisma *)",
      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "Bash(npx tsc *)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://pepeju:password@localhost:5434/accounting_db"
      ],
      "description": "Direct SQL access to the accounting PostgreSQL database for ad-hoc queries and debugging."
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Structured reasoning for API design and schema planning."
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub integration for jjpg-labs/accounting-server."
    }
  }
}