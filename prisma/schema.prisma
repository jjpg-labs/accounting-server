generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                    @id @default(autoincrement())
  email                 String                 @unique
  name                  String
  password              String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  enabled               Boolean                @default(true)
  isAdmin               Boolean                @default(false)
  accountingBooks       AccountingBook[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  refreshTokens         RefreshToken[]
  suppliers             Supplier[]
  passwordResetTokens   PasswordResetToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountingBook {
  id                    Int                    @id @default(autoincrement())
  name                  String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  userId                Int
  isBusiness            Boolean                @default(false)
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories            Category[]
  dailyReports          DailyReport[]
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]

  @@unique([userId, name], map: "AccountingBook_userId_name_unique")
  @@index([userId])
}

model Category {
  id                    Int                    @id @default(autoincrement())
  name                  String
  accountingBookId      Int
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  budgets               Budget[]
  accountingBook        AccountingBook         @relation(fields: [accountingBookId], references: [id], onDelete: Cascade)
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]

  @@unique([accountingBookId, name], map: "Category_bookId_name_unique")
}

model Supplier {
  id           Int           @id @default(autoincrement())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name], map: "Supplier_userId_name_unique")
  @@index([userId])
}

model Transaction {
  id               Int             @id @default(autoincrement())
  description      String?
  amount           Decimal         @db.Decimal(14, 2)
  type             TransactionType
  paymentMethod    PaymentMethod   @default(CASH)
  valueDate        DateTime
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accountingBookId Int
  supplierId       Int?
  categoryId       Int?
  dailyReportId    Int?
  accountingBook   AccountingBook  @relation(fields: [accountingBookId], references: [id], onDelete: Cascade)
  category         Category?       @relation(fields: [categoryId], references: [id])
  dailyReport      DailyReport?    @relation(fields: [dailyReportId], references: [id])
  supplier         Supplier?       @relation(fields: [supplierId], references: [id])

  @@index([accountingBookId])
  @@index([supplierId])
  @@index([valueDate])
  @@index([accountingBookId, valueDate], map: "tx_book_date_idx")
}

model DailyReport {
  id               Int            @id @default(autoincrement())
  date             DateTime
  accountingBookId Int
  openingBalance   Decimal        @db.Decimal(14, 2)
  totalIncome      Decimal        @default(0.00) @db.Decimal(14, 2)
  totalExpense     Decimal        @default(0.00) @db.Decimal(14, 2)
  closingBalance   Decimal        @db.Decimal(14, 2)
  cashLeftForNext  Decimal        @db.Decimal(14, 2)
  removedFromCash  Decimal        @db.Decimal(14, 2)
  reconciled       Boolean        @default(false)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  accountingBook   AccountingBook @relation(fields: [accountingBookId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@unique([accountingBookId, date], map: "DailyReport_book_date_unique")
  @@index([accountingBookId])
}

model Budget {
  id         Int       @id @default(autoincrement())
  name       String
  amount     Decimal   @db.Decimal(14, 2)
  startDate  DateTime
  endDate    DateTime?
  userId     Int
  categoryId Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category? @relation(fields: [categoryId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RecurringTransaction {
  id               Int             @id @default(autoincrement())
  description      String?
  amount           Decimal         @db.Decimal(14, 2)
  type             TransactionType
  paymentMethod    PaymentMethod   @default(CASH)
  frequency        Frequency
  startDate        DateTime
  nextRunDate      DateTime
  lastRunDate      DateTime?
  active           Boolean         @default(true)
  userId           Int
  accountingBookId Int
  categoryId       Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accountingBook   AccountingBook  @relation(fields: [accountingBookId], references: [id], onDelete: Cascade)
  category         Category?       @relation(fields: [categoryId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextRunDate])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}
